# Server
PORT=8080

# Database
DATABASE_URL=postgres://user:password@localhost:5432/sistem_hunian?sslmode=disable

# Auth (Supabase JWT secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Resend (email service)
RESEND_API_KEY=re_your_api_key
RESEND_FROM=SiHuni <noreply@sihuni.id>

# Internal endpoint secrets
CRON_SECRET=your-cron-secret-here
WEBHOOK_SECRET=your-webhook-secret-here

# Supabase (optional, for admin operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
