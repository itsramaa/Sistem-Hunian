# SiHuni Go API — Environment Variables
# Copy to .env and fill in values before running

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

# Database
# Dev: local Docker PostgreSQL
# Prod: swap to Supabase connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sihuni

# Supabase Auth (legacy — kept for reference, no longer required)
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Self-signed JWT Auth
JWT_SECRET=dev-secret-change-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Xendit Payment Gateway
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Resend Email
RESEND_API_KEY=

# Admin secret for 2FA validation
ADMIN_SECRET=

# Cron security
CRON_SECRET=

# Environment: development | production
APP_ENV=development

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_TLS=false
MINIO_BUCKET=sihuni

# RabbitMQ
RABBITMQ_URL=amqp://sihuni:sihuni123@localhost:5672/
