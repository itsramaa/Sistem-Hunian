graph TD
    Start([User Buka App]) --> Role{Pilih Role}
    
    %% ADMIN FLOW
    Role -->|Admin| AdminLogin[Login Admin]
    AdminLogin --> AdminDash[Dashboard Admin]
    AdminDash --> AdminMenu{Pilih Menu}
    
    AdminMenu -->|Merchants| MerchantMgmt[Kelola Merchant]
    MerchantMgmt --> ViewMerchant[Lihat List Merchant]
    ViewMerchant --> MerchantAction{Action}
    MerchantAction -->|Verify| ReviewDoc[Review Dokumen KTP+NPWP+Surat]
    ReviewDoc --> ApproveReject{Approve?}
    ApproveReject -->|Yes| MerchantVerified[Set Status Verified]
    ApproveReject -->|No| RejectReason[Reject + Reason]
    MerchantVerified --> AdminDash
    RejectReason --> AdminDash
    MerchantAction -->|Suspend| SuspendMerchant[Suspend Account]
    SuspendMerchant --> AdminDash
    
    AdminMenu -->|Vendors| VendorMgmt[Kelola Vendor]
    VendorMgmt --> ViewVendor[Lihat List Vendor]
    ViewVendor --> VendorAction{Action}
    VendorAction -->|Verify| ReviewVendorDoc[Review Dokumen KTP+NIB+Foto]
    ReviewVendorDoc --> ApproveVendor{Approve?}
    ApproveVendor -->|Yes| VendorVerified[Set Status Verified]
    ApproveVendor -->|No| RejectVendor[Reject + Reason]
    VendorVerified --> AdminDash
    RejectVendor --> AdminDash
    VendorAction -->|Suspend| SuspendVendor[Suspend Vendor]
    SuspendVendor --> AdminDash
    
    AdminMenu -->|Escrow| EscrowMonitor[Monitor Escrow Transactions]
    EscrowMonitor --> ViewBalance[Lihat Total Escrow Balance]
    ViewBalance --> ViewPending[Pending Disbursements]
    ViewPending --> ManualApprove[Manual Approve Non-Verified]
    ManualApprove --> AdminDash
    
    AdminMenu -->|Subscriptions| SubMgmt[Kelola Subscription]
    SubMgmt --> ViewSubs[Lihat Subscription Status]
    ViewSubs --> ManageTier[Manage Tiers & Pricing]
    ManageTier --> AdminDash
    
    AdminMenu -->|Disputes| DisputeMgmt[Handle Disputes]
    DisputeMgmt --> ViewDispute[Lihat Merchant/Tenant/Vendor Disputes]
    ViewDispute --> ResolveDispute[Resolve + Refund/Compensation]
    ResolveDispute --> AdminDash
    
    AdminMenu -->|Analytics| ViewAdminAnalytics[Platform Analytics]
    ViewAdminAnalytics --> ExportAdminReport[Export Revenue/GMV Report]
    ExportAdminReport --> AdminDash
    
    AdminMenu -->|Referrals| ReferralMgmt[Kelola Referral Program]
    ReferralMgmt --> SetRewards[Set Reward Rules]
    SetRewards --> TrackReferral[Track Referral Performance]
    TrackReferral --> AdminDash
    
    %% MERCHANT FLOW
    Role -->|Merchant| MerchantCheck{Sudah Terdaftar?}
    MerchantCheck -->|Belum| MerchantReg[Self-Register Merchant]
    MerchantReg --> ChooseTier[Pilih Tier Trial]
    ChooseTier --> FreeTrial{Pilih Tier}
    FreeTrial -->|Basic| Basic14Days[14 Hari Trial]
    FreeTrial -->|Pro| Pro7Days[7 Hari Trial]
    FreeTrial -->|Enterprise| Ent3Days[3 Hari Trial]
    Basic14Days --> MerchantLogin
    Pro7Days --> MerchantLogin
    Ent3Days --> MerchantLogin
    
    MerchantCheck -->|Sudah| MerchantLogin[Login Merchant]
    MerchantLogin --> MerchantHome[Home Dashboard]
    MerchantHome --> MerchantMenu{Pilih Menu}
    
    MerchantMenu -->|Profile| MerchantProfile[Edit Profile]
    MerchantProfile --> VerifyAccount{Verify Account?}
    VerifyAccount -->|Yes| UploadMerchantDoc[Upload KTP+NPWP+Surat Property]
    UploadMerchantDoc --> WaitVerify[Tunggu Admin Review 1-2 Hari]
    WaitVerify --> MerchantHome
    VerifyAccount -->|No| MerchantHome
    
    MerchantMenu -->|Properties| PropMgmt[Kelola Properties]
    PropMgmt --> AddProperty[Tambah Property]
    AddProperty --> AddUnits[Tambah Units + Harga]
    AddUnits --> UploadPhotos[Upload Foto Property]
    UploadPhotos --> MerchantHome
    
    MerchantMenu -->|Tenants| TenantMgmt[Kelola Tenants]
    TenantMgmt --> InviteTenant[Generate Link Invitation]
    InviteTenant --> ShareLink[Share via WhatsApp/Email]
    ShareLink --> WaitTenantReg[Tunggu Tenant Register]
    WaitTenantReg --> AssignUnit[Assign Tenant ke Unit]
    AssignUnit --> SetContract[Set Contract Start/End Date]
    SetContract --> GenInvoice[Auto Generate Invoice Bulanan]
    GenInvoice --> MerchantHome
    
    MerchantMenu -->|Payments| PaymentDash[Dashboard Pembayaran]
    PaymentDash --> ViewInvoices[Lihat Status Invoice]
    ViewInvoices --> CheckPayment{Ada Payment Baru?}
    CheckPayment -->|Yes| UpdateEscrow[Update Escrow Balance]
    UpdateEscrow --> MerchantHome
    CheckPayment -->|No| SendReminder[Send Reminder WhatsApp/Email]
    SendReminder --> MerchantHome
    
    MerchantMenu -->|Escrow| EscrowBalance[Lihat Escrow Balance]
    EscrowBalance --> SetDisburse[Set Disbursement Schedule]
    SetDisburse --> ChooseSchedule{Pilih Schedule}
    ChooseSchedule -->|Daily| Daily025[Daily 0.25% Fee]
    ChooseSchedule -->|Weekly| WeeklyFree[Weekly FREE]
    ChooseSchedule -->|Monthly| MonthlyFree[Monthly FREE]
    ChooseSchedule -->|On-Demand| OnDemand05[On-Demand 0.5% Fee]
    Daily025 --> MerchantHome
    WeeklyFree --> MerchantHome
    MonthlyFree --> MerchantHome
    OnDemand05 --> RequestDisburse[Request Manual Disbursement]
    RequestDisburse --> MerchantHome
    
    MerchantMenu -->|Maintenance| MaintDash[Lihat Maintenance Requests]
    MaintDash --> AssignTech[Assign ke Teknisi/Staff]
    AssignTech --> UpdateMaintStatus[Update Status]
    UpdateMaintStatus --> MerchantHome
    
    MerchantMenu -->|Analytics| MerchantAnalytics[Lihat Analytics]
    MerchantAnalytics --> ViewOccupancy[Occupancy Rate]
    ViewOccupancy --> ViewRevenue[Revenue Trends]
    ViewRevenue --> ExportReport[Export CSV/PDF]
    ExportReport --> MerchantHome
    
    MerchantMenu -->|Referral| MerchantReferral[Referral Dashboard]
    MerchantReferral --> GenReferralLink[Generate Referral Link]
    GenReferralLink --> ShareReferral[Share Link]
    ShareReferral --> TrackProgress[Track Referral Progress]
    TrackProgress --> ViewEarnings[Lihat Commission Earned]
    ViewEarnings --> MerchantHome
    
    MerchantMenu -->|Subscription| SubMenu[Manage Subscription]
    SubMenu --> CheckTrial{Trial Expired?}
    CheckTrial -->|Yes| UpgradePrompt[Upgrade to Paid]
    UpgradePrompt --> PaySub[Bayar Subscription]
    PaySub --> MerchantHome
    CheckTrial -->|No| DowngradeOption[Downgrade/Cancel]
    DowngradeOption --> MerchantHome
    
    %% TENANT FLOW
    Role -->|Tenant| TenantCheck{Sudah Terdaftar?}
    TenantCheck -->|Belum| TenantInvite[Klik Link Invitation dari Merchant]
    TenantInvite --> TenantReg[Register via Link]
    TenantReg --> UploadKTP[Upload KTP]
    UploadKTP --> EmergencyContact[Input Emergency Contact]
    EmergencyContact --> ESign[E-Signature Contract]
    ESign --> TenantLogin[Login Tenant]
    
    TenantCheck -->|Sudah| TenantLogin
    TenantLogin --> TenantHome[Home Dashboard]
    TenantHome --> TenantMenu{Pilih Menu}
    
    TenantMenu -->|Payment| TenantPayment[Lihat Invoice]
    TenantPayment --> HasInvoice{Ada Tagihan?}
    HasInvoice -->|Ya| SelectPayMethod[Pilih Metode Bayar]
    SelectPayMethod --> XenditPay[Bayar via Xendit VA/QRIS/Ewallet/CC]
    XenditPay --> PaySuccess{Sukses?}
    PaySuccess -->|Ya| ToEscrow[Masuk Escrow SiHuni]
    ToEscrow --> NotifMerchant[Notif ke Merchant]
    NotifMerchant --> TenantHome
    PaySuccess -->|No| RetryPay[Coba Lagi]
    RetryPay --> SelectPayMethod
    HasInvoice -->|Tidak| ViewHistory[Lihat Payment History]
    ViewHistory --> DownloadReceipt[Download PDF Receipt]
    DownloadReceipt --> TenantHome
    
    TenantMenu -->|Vendor| BrowseVendor[Browse Vendor Marketplace]
    BrowseVendor --> FilterCategory[Filter by Category]
    FilterCategory --> ViewVendorProfile[Lihat Vendor Profile]
    ViewVendorProfile --> OrderVendor{Order?}
    OrderVendor -->|Ya| PlaceOrder[Pesan Produk/Jasa]
    PlaceOrder --> PayVendor[Bayar via Xendit]
    PayVendor --> VendorEscrow[Masuk Escrow]
    VendorEscrow --> WaitConfirm[Tunggu Vendor Confirm]
    WaitConfirm --> OrderComplete[Order Completed]
    OrderComplete --> RateVendor[Beri Rating & Review]
    RateVendor --> VendorDisburse[Vendor Dapat Disbursement]
    VendorDisburse --> TenantHome
    OrderVendor -->|Tidak| TenantHome
    
    TenantMenu -->|Maintenance| CreateMaint[Buat Maintenance Request]
    CreateMaint --> UploadMaintPhoto[Upload Foto Masalah]
    UploadMaintPhoto --> SubmitMaint[Submit Request]
    SubmitMaint --> TrackMaint[Track Status Real-time]
    TrackMaint --> TenantHome
    
    TenantMenu -->|Forum| ViewForum[Lihat Forum]
    ViewForum --> ForumType{Pilih Forum}
    ForumType -->|Global| GlobalForum[Global Forum All Tenants]
    ForumType -->|Property| PrivateForum[Private Forum Property]
    GlobalForum --> ForumAction{Action}
    PrivateForum --> ForumAction
    ForumAction -->|Post| CreatePost[Buat Post Baru]
    ForumAction -->|Comment| AddComment[Comment Post]
    ForumAction -->|Like| LikePost[Like Post]
    CreatePost --> TenantHome
    AddComment --> TenantHome
    LikePost --> TenantHome
    
    TenantMenu -->|Referral| TenantReferral[Referral Dashboard]
    TenantReferral --> GenTenantLink[Generate Link]
    GenTenantLink --> ShareTenantLink[Share ke Teman]
    ShareTenantLink --> TrackTenantReferral[Track Progress]
    TrackTenantReferral --> ViewVoucher[Lihat Voucher Balance]
    ViewVoucher --> TenantHome
    
    TenantMenu -->|Chatbot| OpenChat[Buka AI Chatbot]
    OpenChat --> AskBot[Tanya Pertanyaan]
    AskBot --> BotIntent{Detect Intent}
    BotIntent -->|FAQ| AnswerFAQ[Jawab FAQ]
    BotIntent -->|Vendor Rec| RecommendVendor[Rekomen Vendor Terdekat]
    BotIntent -->|Maintenance| MaintAssist[Panduan Troubleshoot]
    AnswerFAQ --> TenantHome
    RecommendVendor --> TenantHome
    MaintAssist --> TenantHome
    
    %% VENDOR FLOW
    Role -->|Vendor| VendorCheck{Sudah Terdaftar?}
    VendorCheck -->|Belum| VendorReg[Self-Register Vendor]
    VendorReg --> VendorProfile[Input Business Info]
    VendorProfile --> UploadVendorDoc[Upload KTP+NIB+Foto Tempat]
    UploadVendorDoc --> WaitVendorVerify[Tunggu Admin Review]
    WaitVendorVerify --> VendorActive[Vendor Active Non-Verified]
    VendorActive --> VendorLogin
    
    VendorCheck -->|Sudah| VendorLogin[Login Vendor]
    VendorLogin --> VendorHome[Home Dashboard]
    VendorHome --> VendorMenu{Pilih Menu}
    
    VendorMenu -->|Products| ManageProducts[Kelola Produk/Jasa]
    ManageProducts --> AddProduct[Tambah Produk]
    AddProduct --> UploadProductPhoto[Upload Foto Produk]
    UploadProductPhoto --> SetPrice[Set Harga + Deskripsi]
    SetPrice --> VendorHome
    
    VendorMenu -->|Orders| ViewOrders[Lihat Order Masuk]
    ViewOrders --> NewOrder{Ada Order Baru?}
    NewOrder -->|Ya| AcceptReject{Accept?}
    AcceptReject -->|Accept| ConfirmOrder[Confirm Order]
    ConfirmOrder --> ProcessOrder[Update Status Processing]
    ProcessOrder --> CompleteOrder[Mark as Completed]
    CompleteOrder --> WaitTenantReview[Tunggu Tenant Review]
    WaitTenantReview --> VendorGetPaid[Escrow → Vendor Balance]
    VendorGetPaid --> VendorHome
    AcceptReject -->|Reject| RejectOrder[Reject + Reason]
    RejectOrder --> RefundTenant[Auto Refund ke Tenant]
    RefundTenant --> VendorHome
    NewOrder -->|Tidak| VendorHome
    
    VendorMenu -->|Escrow| VendorEscrowDash[Lihat Escrow Balance]
    VendorEscrowDash --> SetVendorDisburse[Set Disbursement Schedule]
    SetVendorDisburse --> VendorSchedule{Pilih Schedule}
    VendorSchedule -->|Daily| VendorDaily[Daily 0.25%]
    VendorSchedule -->|Weekly| VendorWeekly[Weekly FREE]
    VendorSchedule -->|Monthly| VendorMonthly[Monthly FREE]
    VendorDaily --> VendorHome
    VendorWeekly --> VendorHome
    VendorMonthly --> VendorHome
    
    VendorMenu -->|Analytics| VendorAnalytics[Sales Analytics]
    VendorAnalytics --> TopProducts[Top Selling Products]
    TopProducts --> CustomerInsights[Customer Insights]
    CustomerInsights --> VendorHome
    
    VendorMenu -->|Referral| VendorReferral[Referral Dashboard]
    VendorReferral --> GenVendorLink[Generate Link]
    GenVendorLink --> ShareVendorLink[Share Link]
    ShareVendorLink --> TrackVendorProgress[Track Progress]
    TrackVendorProgress --> ViewCashback[Lihat Cashback Earned]
    ViewCashback --> VendorHome
    
    %% CHATBOT UNIVERSAL
    TenantHome -.->|Floating Button| UnivChatbot[AI Chatbot Gemini]
    MerchantHome -.->|Floating Button| UnivChatbot
    VendorHome -.->|Floating Button| UnivChatbot
    
    UnivChatbot --> ChatQuery[Input Query]
    ChatQuery --> GeminiProcess[Gemini API Process]
    GeminiProcess --> ChatResponse{Response Type}
    ChatResponse -->|FAQ| ShowFAQ[Show Answer + Links]
    ChatResponse -->|Vendor Rec| ShowVendors[Show Top 3 Vendors]
    ChatResponse -->|Data Query| QueryDB[Query Database]
    ChatResponse -->|Unknown| AskClarify[Minta Klarifikasi]
    ShowFAQ --> ChatEnd[Chat Selesai]
    ShowVendors --> ChatEnd
    QueryDB --> ChatEnd
    AskClarify --> ChatQuery
    
    ChatEnd -.-> TenantHome
    ChatEnd -.-> MerchantHome
    ChatEnd -.-> VendorHome
    
    style AdminDash fill:#e1f5ff
    style MerchantHome fill:#fff3e0
    style TenantHome fill:#f3e5f5
    style VendorHome fill:#e8f5e9
    style UnivChatbot fill:#c8e6c9
    style XenditPay fill:#ffeb3b
    style ToEscrow fill:#ff9800
    style VendorEscrow fill:#ff9800
    style PaySuccess fill:#4caf50
    style MerchantVerified fill:#4caf50
    style VendorVerified fill:#4caf50